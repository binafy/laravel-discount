{
    "name": "binafy/laravel-discount",
    "description": "The Laravel-Discount is a Laravel package designed to handle discounts in your application effortlessly",
    "keywords": [
        "php",
        "binafy",
        "milwad",
        "laravel",
        "framework",
        "discount",
        "laravel-discount",
        "laravel discount",
        "coupon",
        "promo",
        "promotion",
        "voucher",
        "coupon-code",
        "discount-code",
        "pricing",
        "ecommerce",
        "shopping-cart",
        "cart",
        "checkout",
        "sales",
        "offers",
        "laravel-package",
        "eloquent"
    ],
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "authors": [
        {
            "name": "Milwad Khosravi",
            "email": "milwad.dev@gmail.com",
            "role": "author",
            "homepage": "https://github.com/milwad-dev"
        },
        {
            "name": "Binafy",
            "role": "owner",
            "homepage": "https://github.com/binafy"
        }
    ],
    "autoload": {
        "psr-4": {
            "Binafy\\LaravelDiscount\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.1",
        "laravel/framework": "^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "pestphp/pest-plugin-laravel": "^1.4.0|^2.0.0|^3.0.0|^4.0.0",
        "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0|^11.0",
        "binafy/laravel-cart": "^2.1"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Binafy\\LaravelDiscount\\Providers\\LaravelDiscountServiceProvider"
            ],
            "aliases": {
                "LaravelDiscount": "Binafy\\LaravelDiscount\\Facades\\LaravelDiscount"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "audit": {
            "block-insecure": false
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage-html ./coverage"
    },
    "suggest": {
        "binafy/laravel-cart": "Required to apply discounts to carts and cart items (^2.0)."
    }
}
